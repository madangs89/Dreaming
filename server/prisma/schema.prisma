generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  email
  google
  github
}

enum Memetype {
  image
  video
  audio
  pdf
  document
  spreadsheet
  presentation
  text
  archive
  code
  font
  executable
  model
  other
}

enum ReviewStatus {
  scheduled
  attempted
  completed
  missed
}

enum reviewRememberStatus {
  easy
  partial
  forgot
}

enum question_type {
  coding
  text
}

enum difficulty {
  easy
  medium
  hard
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  password    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  provider    Provider @default(email)
  profile_url String?
  public_id   String?
  topics      Topic[]
  reviews     review[]
}

model Topic {
  id         String   @id @default(uuid())
  title      String
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  source_url String?
  public_id  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  notes      Note[]
  reviews    review[]
}

model Note {
  id                String            @id @default(uuid())
  title             String
  content           String?
  topic_id          String
  topic             Topic             @relation(fields: [topic_id], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  titleTimeStamp    DateTime          @default(now())
  contentTimeStamp  DateTime          @default(now())
  documents         Document[]
  reviews           review[]
  questionHistories QuestionHistory[]
}

model Document {
  id        String   @id @default(uuid())
  notes_id  String
  notes     Note     @relation(fields: [notes_id], references: [id])
  url       String
  memetype  Memetype
  title     String
  public_id String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model review {
  id                 String                @id @default(uuid())
  user_id            String
  user               User                  @relation(fields: [user_id], references: [id])
  notes_id           String
  topic_id           String
  scheduled_date     DateTime
  status             ReviewStatus          @default(scheduled)
  is_completed       Boolean               @default(false)
  review_results     reviewRememberStatus?
  review_count       Int                   @default(1)
  strong_areas       String[]              @default([])
  weak_areas         String[]              @default([])
  is_revision_enough Boolean               @default(false)
  notes              Note                  @relation(fields: [notes_id], references: [id])
  topic              Topic                 @relation(fields: [topic_id], references: [id])
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  questionHistories  QuestionHistory[]
}

model QuestionHistory {
  id             String        @id @default(uuid())
  notes_id       String
  notes          Note          @relation(fields: [notes_id], references: [id])
  review_id      String
  review         review        @relation(fields: [review_id], references: [id])
  expectedAnswer String
  question_type  question_type @default(text)
  difficulty     difficulty    @default(easy)
  question       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}
